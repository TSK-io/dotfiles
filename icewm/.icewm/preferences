# Personal IceWM preferences.

TaskBarAutoHide=1

# i3-style workspace switching.
KeySysWorkspace1="Super+1"
KeySysWorkspace2="Super+2"
KeySysWorkspace3="Super+3"
KeySysWorkspace4="Super+4"

# i3-style floating window mouse controls.
MouseWinMove="Super+Pointer_Button1"
MouseWinSize="Super+Pointer_Button3"

# macOS-style fullscreen toggle.
KeyWinFullscreen="Ctrl+Super+f"

# macOS-style window switching.
KeySysSwitchNext="Super+Tab"
KeySysSwitchLast="Super+Shift+Tab"
KeySysSwitchClass="Super+grave"
