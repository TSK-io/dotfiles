# Personal IceWM keybindings.
# This file replaces the system keys file, so keep default bindings here
# when they should remain active.

key "Super+Return"          alacritty
key "Super+space"           rofi -show drun -show-icons
key "Super+e"               /bin/sh -lc 'exec "$HOME/.icewm/scripts/file-manager.sh"'
key "Super+w"               icesh -f close
key "Super+n"               flameshot gui
key "Super+m"               flameshot gui -c -s

key "Super+KP_Subtract"     wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%-
key "Super+KP_Add"          wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%+

key "XF86AudioLowerVolume"  wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%-
key "XF86AudioRaiseVolume"  wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%+
key "XF86AudioMute"         wpctl set-mute   @DEFAULT_AUDIO_SINK@ toggle
key "XF86HomePage"          sensible-browser about:blank
key "XF86Search"            sensible-browser https://www.duckduckgo.com
key "XF86Eject"             eject
key "XF86Calculator"        /bin/sh -c "gnome-calculator || xcalc || ( type bc >/dev/null 2>&1 && x-terminal-emulator -e bc -l)"

switchkey "Super+p"         icewm-menu-xrandr
key "Super+z"               /bin/sh -lc 'exec alacritty --working-directory "$HOME/dotfiles" -e "$HOME/.local/bin/claude"'
key "Super+x"               /bin/sh -lc 'exec alacritty --working-directory "$HOME/dotfiles" -e "$HOME/.npm-global/bin/codex"'
key "Super+c"               /bin/sh -lc 'exec alacritty --working-directory "$HOME/dotfiles" -e "$HOME/.local/bin/copilot"'
key "Super+v"               /bin/sh -lc 'exec alacritty --working-directory "$HOME/dotfiles" -e "$HOME/.local/bin/agy"'

key "Super+comma"           /bin/sh -lc 'exec "$HOME/.icewm/scripts/quick-pick.sh" "$HOME/.icewm/scripts/quick-prompts.txt" prompts'
key "Super+period"          /bin/sh -lc 'exec "$HOME/.icewm/scripts/quick-pick.sh" "$HOME/.icewm/scripts/quick-commands.txt" commands'


