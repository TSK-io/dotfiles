# Personal IceWM keybindings.
# This file replaces the system keys file, so keep default bindings here
# when they should remain active.

key "Super+w"  		    icesh -f close
key "Super+Return"          kitty --start-as fullscreen 
key "Super+space"           rofi -show drun -show-icons
key "Super+e"               pcmanfm 
key "Super+m"               flameshot gui
key "Ctrl+Super+Right"      flameshot gui -c -s 
key "Super+z"       	    /bin/sh -c 'flameshot full -c && xdg-open "https://translate.google.com/?sl=auto&tl=zh-CN&op=images"' 
key "Super+c"               /bin/sh -lc 'exec "$HOME/.icewm/scripts/screenshot-to-claude.sh"'
key "Super+x"               /bin/sh -lc 'exec "$HOME/.icewm/scripts/quick-pick.sh"'

switchkey "Super+p"         icewm-menu-xrandr
key "XF86AudioLowerVolume"  wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%-
key "XF86AudioRaiseVolume"  wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%+
key "XF86AudioMute"         wpctl set-mute   @DEFAULT_AUDIO_SINK@ toggle

